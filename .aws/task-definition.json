{
    "family": "koperasi-task",
    "networkMode": "awsvpc",
    "containerDefinitions": [
        {
            "name": "URI_ECR",
            "image": "226638406978.dkr.ecr.us-east-1.amazonaws.com/koperasi-app:latest",
            "portMappings": [
                {
                    "containerPort": 3000,
                    "hostPort": 3000,
                    "protocol": "tcp"
                }
            ],
            "essential": true,
            "memory": 512,
            "memoryReservation": 256,
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/koperasi-task",
                    "awslogs-region": "us-east-1",
                    "awslogs-stream-prefix": "ecs"
                }
            }
        }
    ],
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "cpu": "512",
    "memory": "1024",
    "executionRoleArn": "arn:aws:iam::226638406978:role/LabRole",
    "taskRoleArn": "arn:aws:iam::226638406978:role/LabRole"
}
